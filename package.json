{
  "name": "glasskit-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/glasskit-ui.umd.js",
  "module": "./dist/glasskit-ui.es.js",
  "exports": {
    ".": {
      "import": "./dist/glasskit-ui.es.js",
      "require": "./dist/glasskit-ui.umd.js"
    },
